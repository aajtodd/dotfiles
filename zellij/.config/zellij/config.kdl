// Zellij configuration. Stowed to ~/.config/zellij/config.kdl
// See https://zellij.dev/documentation/options for all options.
// (New panes/tabs already open in the focused pane's cwd by default.)
//
// Keybinds are ADDITIVE: no `clear-defaults=true`, so the stock 0.44 keymap
// stays intact and the `keybinds` block below only adds our own bindings.

// Use zsh as the shell inside panes.
default_shell "zsh"

// Scrollback edit uses neovim (mirrors EDITOR=nvim).
scrollback_editor "nvim"

// Clipboard via OSC52 so copy works locally and over SSH
// (terminal must support it -- WezTerm does). Leaving copy_command
// unset is what keeps zellij on the OSC52 path.
// "system" targets the OS clipboard (macOS Cmd-V / paste), NOT the X11
// primary selection -- zellij intercepts apps' OSC52 and re-emits with
// this target, so "primary" would make nvim's "+y unreachable via Cmd-V.
copy_clipboard "system"
copy_on_select true

// Keep the UI minimal.
pane_frames false

// No startup tips banner on a new session.
show_startup_tips false

// Don't prompt on exit.
on_force_close "quit"

// Browser terminal client (`zellij web`). Kept for screen-sharing / pairing
// over a tunnel (tunnels.lab.aws.dev); monospace so the shared view renders
// with a plain terminal font.
web_client {
    font "monospace"
}

keybinds {
    // Claude launcher (zj-claude): spawn the binary in a floating pane that
    // closes when it exits. `Run` executes a command -- zj-claude is a plain
    // executable on PATH, not a plugin. Bound everywhere except locked mode so
    // it is reachable without a mode prefix.
    shared_except "locked" {
        bind "Ctrl y" {
            Run "zj-claude" {
                floating true
                close_on_exit true
                width "80%"
                height "80%"
                x "10%"
                y "10%"
            }
        }
    }
}
